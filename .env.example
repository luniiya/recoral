# Copy this file to .env (same folder as docker-compose.yml) and adjust as
# needed. All variables are optional, sensible defaults are baked into
# docker-compose.release.yml if you don't set them.

# Which published version to run. "latest" tracks the most recent release;
# pin to a specific tag (e.g. v1.0.0) if you'd rather upgrade deliberately.
RECORAL_VERSION=latest

# Port recoral is reachable on, on the host machine.
RECORAL_PORT=7245

# Where your recordings/database and downloaded whisper models are stored,
# on the host machine (not inside the container). Defaults to a ./data
# folder right next to this file, easy to find and back up. Change these if
# you'd rather keep them somewhere else, e.g. an external drive.
RECORAL_DATA_LOCATION=./data
RECORAL_MODELS_LOCATION=./data/models
